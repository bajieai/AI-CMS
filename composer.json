{
    "name": "aicms/v2",
    "description": "AI-CMS V2.0 - Enterprise Information Management System based on ThinkPHP 8.1",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "ext-json": "*",
        "ext-pdo": "*",
        "guzzlehttp/guzzle": "^7.8",
        "phpoffice/phpspreadsheet": "^2.0",
        "symfony/polyfill-intl-normalizer": "^1.37",
        "topthink/framework": "^8.1",
        "topthink/think-multi-app": "^1.0",
        "topthink/think-view": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "app\\": "app/"
        },
        "files": [
            "app/common/helper.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "topthink/think-installer": true
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "php think clear"
        ],
        "migrate": "bin\\migrate.bat",
        "migrate:ps1": "powershell -ExecutionPolicy Bypass -File bin\\migrate.ps1"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
