# AI-CMS V2.0 环境配置模板
# 复制此文件为 .env 并根据实际情况修改配置

# ==================== 应用配置 ====================
# 调试模式（生产环境请设为 false）
APP_DEBUG = false

# ==================== 数据库配置 ====================
# 数据库类型：mysql / pgsql / sqlite
DATABASE_TYPE = mysql
# 数据库服务器地址
DATABASE_HOSTNAME = 127.0.0.1
# 数据库名
DATABASE_DATABASE = aicms_v2
# 数据库用户名
DATABASE_USERNAME = root
# 数据库密码
DATABASE_PASSWORD = 
# 数据库端口
DATABASE_HOSTPORT = 3306
# 数据库字符集
DATABASE_CHARSET = utf8mb4
# 数据表前缀
DATABASE_PREFIX = i8j_

# ==================== 缓存配置 ====================
# 缓存驱动：file / redis
CACHE_DRIVER = file

# ==================== AI 服务配置 ====================
# DeepSeek API 基础地址
AI_DEEPSEEK_BASE_URL = https://api.deepseek.com
# DeepSeek API 密钥（必填，否则AI功能不可用）
# 获取地址：https://platform.deepseek.com/api_keys
AI_DEEPSEEK_API_KEY = 
# DeepSeek 模型名称
AI_DEEPSEEK_MODEL = deepseek-chat

# ==================== Session 配置 ====================
# Session 驱动：file / redis
SESSION_TYPE = file
# Session 有效期（秒）
SESSION_EXPIRE = 7200

# ==================== OAuth 配置 ====================
# Gitee OAuth 应用配置（如需启用Gitee登录，请填写）
# 申请地址：https://gitee.com/oauth/applications
OAUTH_GITEE_CLIENT_ID = 
OAUTH_GITEE_CLIENT_SECRET = 

# ==================== 安全配置 ====================
# 后台登录密码加密密钥（安装时自动生成，请勿泄露）
AUTH_KEY = 
# CSRF Token 有效期（秒）
CSRF_EXPIRE = 7200
