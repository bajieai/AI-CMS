<!-- V2.9 个人中心页面 -->
<view class="container">
  <!-- 用户信息 -->
  <view class="user-info">
    <block wx:if="{{isLogin}}">
      <image class="avatar" src="{{memberInfo.avatar || '/images/default_avatar.png'}}" mode="aspectFill"/>
      <view class="user-detail">
        <text class="nickname">{{memberInfo.nickname || memberInfo.username}}</text>
        <text class="points">积分: {{points}}</text>
      </view>
    </block>
    <block wx:else>
      <image class="avatar" src="/images/default_avatar.png" mode="aspectFill"/>
      <view class="user-detail">
        <button class="login-btn" bindtap="handleLogin">微信一键登录</button>
      </view>
    </block>
  </view>

  <!-- 数据概览 -->
  <view class="stats-bar" wx:if="{{isLogin}}">
    <view class="stat-item" bindtap="goSignin">
      <text class="stat-num">{{signinDays}}</text>
      <text class="stat-label">签到天数</text>
    </view>
    <view class="stat-item" bindtap="goCoupon">
      <text class="stat-num">{{couponCount}}</text>
      <text class="stat-label">优惠券</text>
    </view>
    <view class="stat-item" bindtap="goOrders">
      <text class="stat-num">{{orderCount}}</text>
      <text class="stat-label">订单</text>
    </view>
    <view class="stat-item" bindtap="handleInvite">
      <text class="stat-num">{{inviteCount}}</text>
      <text class="stat-label">邀请</text>
    </view>
  </view>

  <!-- 签到卡片 -->
  <view class="signin-card" wx:if="{{isLogin}}">
    <view class="signin-info">
      <text class="signin-days">连续签到 {{signinDays}} 天</text>
      <button class="signin-btn {{hasSignedToday ? 'signed' : ''}}" bindtap="goSignin">
        {{hasSignedToday ? '已签到' : '立即签到'}}
      </button>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-list">
    <navigator url="/pages/index/index" class="menu-item">
      <text class="icon">🏠</text>
      <text class="title">首页</text>
      <text class="arrow">></text>
    </navigator>
    <navigator url="/pages/search/search" class="menu-item">
      <text class="icon">🔍</text>
      <text class="title">搜索</text>
      <text class="arrow">></text>
    </navigator>
    <view class="menu-item" bindtap="goCoupon" wx:if="{{isLogin}}">
      <text class="icon">🎟</text>
      <text class="title">我的优惠券</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="handleInvite" wx:if="{{isLogin}}">
      <text class="icon">🎁</text>
      <text class="title">邀请好友</text>
      <text class="arrow">></text>
    </view>
  </view>

  <!-- 退出登录 -->
  <button class="logout-btn" wx:if="{{isLogin}}" bindtap="handleLogout">退出登录</button>
</view>
