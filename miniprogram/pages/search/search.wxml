<view class="container">
  <view class="card" style="display:flex;align-items:center;padding:16rpx 24rpx;">
    <input
      placeholder="输入关键词搜索"
      value="{{keyword}}"
      bindinput="onInput"
      confirm-type="search"
      bindconfirm="onSearch"
      style="flex:1;font-size:28rpx;"
    />
    <button class="btn-primary" size="mini" bindtap="onSearch" style="margin-left:16rpx;">搜索</button>
  </view>

  <view wx:for="{{list}}" wx:key="id" class="card" bindtap="goDetail" data-id="{{item.id}}">
    <view class="title">{{item.title}}</view>
    <view class="desc">{{item.excerpt}}</view>
  </view>

  <view wx:if="{{!loading && list.length === 0 && keyword}}" class="empty">无搜索结果</view>
  <view wx:if="{{loading}}" class="empty">搜索中...</view>
</view>
