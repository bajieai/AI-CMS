<view class="container">
  <!-- V2.9: 新人券弹窗 -->
  <view class="newbie-coupon-modal" wx:if="{{showNewbieCoupon}}">
    <view class="newbie-coupon-mask" bindtap="closeNewbieCoupon"></view>
    <view class="newbie-coupon-content">
      <view class="newbie-coupon-header">
        <text class="newbie-coupon-title">🎁 新人专属福利</text>
        <text class="newbie-coupon-close" bindtap="closeNewbieCoupon">✕</text>
      </view>
      <view class="newbie-coupon-body">
        <text class="newbie-coupon-desc">注册即送优惠券，快来领取吧！</text>
        <view class="newbie-coupon-card" wx:if="{{newbieCouponInfo}}">
          <text class="coupon-name">{{newbieCouponInfo.coupon_name || '新人优惠券'}}</text>
          <text class="coupon-value" wx:if="{{newbieCouponInfo.coupon_type === 'reduce'}}">¥{{newbieCouponInfo.reduce_amount}}</text>
          <text class="coupon-value" wx:elif="{{newbieCouponInfo.coupon_type === 'discount'}}">{{newbieCouponInfo.reduce_amount}}折</text>
          <text class="coupon-condition" wx:if="{{newbieCouponInfo.condition_amount > 0}}">满{{newbieCouponInfo.condition_amount}}可用</text>
          <text class="coupon-condition" wx:else>无门槛</text>
        </view>
        <button class="newbie-coupon-btn" bindtap="receiveNewbieCoupon">立即领取</button>
      </view>
    </view>
  </view>

  <view wx:for="{{list}}" wx:key="id" class="card" bindtap="goDetail" data-id="{{item.id}}">
    <image wx:if="{{item.cover}}" src="{{item.cover}}" mode="aspectFill" style="width:100%;height:360rpx;border-radius:12rpx;margin-bottom:16rpx;" />
    <view class="title">{{item.title}}</view>
    <view class="desc">{{item.excerpt}}</view>
    <view class="meta">
      <text wx:if="{{item.is_paid}}" style="color:#e64340;">付费内容</text>
      <text wx:else>免费</text>
      <text style="margin-left:20rpx;">{{item.views}} 阅读</text>
    </view>
  </view>

  <view wx:if="{{!loading && list.length === 0}}" class="empty">暂无内容</view>
  <view wx:if="{{loading}}" class="empty">加载中...</view>
  <view wx:if="{{!hasMore && list.length > 0}}" class="empty">已经到底了</view>
</view>
