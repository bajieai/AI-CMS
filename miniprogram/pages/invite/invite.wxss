/* invite.wxss - 邀请好友页 */
.invite-header {
  display: flex;
  background: linear-gradient(135deg, #3b82f6, #6366f1);
  border-radius: 12rpx;
  padding: 40rpx 24rpx;
  margin-bottom: 20rpx;
}
.invite-stat {
  flex: 1;
  text-align: center;
  color: #fff;
}
.invite-stat .stat-num {
  font-size: 44rpx;
  font-weight: 700;
  display: block;
}
.invite-stat .stat-label {
  font-size: 24rpx;
  opacity: 0.8;
  display: block;
  margin-top: 4rpx;
}
.invite-link-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}
.link-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}
.link-box {
  display: flex;
  align-items: center;
  background: #f8fafc;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 16rpx;
}
.link-text {
  flex: 1;
  font-size: 24rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.copy-btn {
  background: #3b82f6;
  color: #fff;
  border-radius: 8rpx;
  margin-left: 12rpx;
}
.share-btn {
  background: #07c160;
  color: #fff;
  border-radius: 20rpx;
  font-size: 28rpx;
}
.reward-stages {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}
.reward-stages .section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}
.stage-track {
  padding-left: 0;
}
.stage-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.stage-item:last-child {
  border-bottom: none;
}
.stage-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}
.stage-info {
  flex: 1;
}
.stage-label {
  font-size: 28rpx;
  color: #333;
  display: block;
}
.stage-desc {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}
.stage-reward {
  text-align: right;
  margin-right: 16rpx;
}
.stage-count {
  font-size: 26rpx;
  color: #666;
  display: block;
}
.stage-points {
  font-size: 24rpx;
  color: #f59e0b;
  display: block;
}
.stage-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
}
.stage-badge.done {
  background: rgba(7,193,96,0.1);
  color: #07c160;
}
.stage-badge.active {
  background: rgba(59,130,246,0.1);
  color: #3b82f6;
}
.stage-badge.locked {
  background: #f5f5f5;
  color: #ccc;
}
.records {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
}
.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.record-item:last-child {
  border-bottom: none;
}
.record-name {
  font-size: 28rpx;
  color: #333;
  display: block;
}
.record-time {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}
.record-points {
  font-size: 28rpx;
  color: #f59e0b;
  font-weight: 600;
}
