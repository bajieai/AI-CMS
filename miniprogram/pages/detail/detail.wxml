<view class="container">
  <view wx:if="{{loading}}" class="empty">加载中...</view>

  <block wx:if="{{info && !loading}}">
    <view class="card">
      <view class="title">{{info.title}}</view>
      <view class="meta">
        <text>{{info.cate?.name}}</text>
        <text style="margin-left:20rpx;">{{info.views}} 阅读</text>
      </view>
    </view>

    <!-- 付费提示与购买入口 -->
    <view class="card" wx:if="{{info.price > 0 && !hasPaid}}">
      <view class="pay-banner">
        <text class="pay-price">¥{{info.price}}</text>
        <button class="pay-btn" bindtap="handleBuy">立即购买</button>
      </view>
    </view>

    <view class="card">
      <rich-text wx:if="{{info.content && (info.price <= 0 || hasPaid)}}" nodes="{{info.content}}"></rich-text>
      <view wx:elif="{{info.price > 0 && !hasPaid}}" class="empty">该内容需付费后查看</view>
      <view wx:else class="empty">暂无内容</view>
    </view>

    <!-- 章节列表 -->
    <view wx:if="{{chapters.length > 0}}" class="card">
      <view class="title" style="font-size:30rpx;margin-bottom:16rpx;">章节列表</view>
      <view wx:for="{{chapters}}" wx:key="id" style="padding:16rpx 0;border-bottom:1rpx solid #eee;">
        <text>{{item.chapter_title || item.title}}</text>
        <text wx:if="{{item.is_free_chapter}}" style="color:#07c160;margin-left:12rpx;font-size:24rpx;">免费</text>
        <text wx:else style="color:#e64340;margin-left:12rpx;font-size:24rpx;">付费</text>
      </view>
    </view>

    <!-- 评分评价 -->
    <view class="card" wx:if="{{ratingSummary}}">
      <view class="rating-header" style="display:flex;justify-content:space-between;align-items:center;">
        <view>
          <text class="rating-score" style="font-size:48rpx;font-weight:700;color:#f59e0b;">{{ratingSummary.avg_score || 0}}</text>
          <text class="rating-count" style="margin-left:12rpx;color:#999;">{{ratingSummary.total_count || 0}}条评价</text>
        </view>
        <button class="rate-btn" size="mini" bindtap="openRatingModal" style="background:#3b82f6;color:#fff;border:none;border-radius:20rpx;">写评价</button>
      </view>
    </view>
    <view class="card" wx:if="{{ratings.length > 0}}">
      <view class="title" style="font-size:30rpx;margin-bottom:16rpx;">最新评价</view>
      <view wx:for="{{ratings}}" wx:key="id" class="rating-item" style="padding:16rpx 0;border-bottom:1rpx solid #f5f5f5;">
        <view style="display:flex;justify-content:space-between;align-items:center;">
          <text class="rating-star" style="color:#f59e0b;">★ {{item.rating}}</text>
          <text style="font-size:24rpx;color:#999;">{{item.is_anonymous ? '匿名用户' : (item.nickname || '用户')}}</text>
        </view>
        <text class="rating-content" style="display:block;margin-top:8rpx;font-size:28rpx;color:#333;">{{item.content}}</text>
      </view>
    </view>
  </block>

  <!-- V2.9: 评价弹窗 -->
  <view class="rating-modal" wx:if="{{showRatingModal}}">
    <view class="rating-modal-mask" bindtap="closeRatingModal"></view>
    <view class="rating-modal-content">
      <view class="rating-modal-header">
        <text style="font-weight:700;font-size:32rpx;">发表评价</text>
        <text class="rating-modal-close" bindtap="closeRatingModal">✕</text>
      </view>
      <view class="rating-modal-body">
        <!-- 星级选择 -->
        <view class="star-selector" style="text-align:center;padding:24rpx 0;">
          <text wx:for="{{[1,2,3,4,5]}}" wx:key="*this"
                data-value="{{item}}"
                bindtap="selectRating"
                style="font-size:56rpx;margin:0 8rpx;color:{{item <= ratingValue ? '#f59e0b' : '#ddd'}};">★</text>
        </view>
        <textarea class="rating-textarea" placeholder="分享您的评价..." value="{{ratingContent}}"
                  bindinput="onRatingInput"
                  maxlength="500" style="width:100%;min-height:160rpx;border:1rpx solid #e2e8f0;border-radius:12rpx;padding:16rpx;font-size:28rpx;"></textarea>
        <view style="display:flex;align-items:center;margin-top:16rpx;">
          <switch checked="{{isAnonymous}}" bindchange="toggleAnonymous" color="#3b82f6" style="transform:scale(0.8);"/>
          <text style="font-size:26rpx;color:#666;">匿名评价</text>
        </view>
      </view>
      <view class="rating-modal-footer" style="padding:20rpx;">
        <button class="submit-rating-btn" bindtap="submitRating" style="background:#3b82f6;color:#fff;border-radius:20rpx;">提交评价</button>
      </view>
    </view>
  </view>
</view>
