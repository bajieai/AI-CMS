/* signin.wxss - 签到页 */
.signin-header {
  background: linear-gradient(135deg, #07c160, #06ad56);
  border-radius: 12rpx;
  padding: 40rpx 24rpx;
  text-align: center;
  color: #fff;
  margin-bottom: 20rpx;
}
.signin-days {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}
.signin-points {
  font-size: 26rpx;
  display: block;
  margin-bottom: 24rpx;
}
.signin-btn {
  background: #fff;
  color: #07c160;
  border-radius: 20rpx;
  font-size: 30rpx;
  padding: 16rpx 48rpx;
  display: inline-block;
}
.signin-btn.signed {
  background: rgba(255,255,255,0.3);
  color: #fff;
}
.weekly-progress {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}
.weekly-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}
.weekly-track {
  display: flex;
  justify-content: space-between;
}
.milestone-node {
  text-align: center;
  flex: 1;
}
.milestone-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: #e2e8f0;
  margin: 0 auto 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
}
.milestone-dot-large {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
}
.milestone-node.achieved .milestone-dot {
  background: #07c160;
}
.milestone-node.current .milestone-dot {
  background: #3b82f6;
}
.milestone-day {
  font-size: 22rpx;
  color: #666;
  display: block;
}
.milestone-reward {
  font-size: 20rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}
.milestone-reward-hot {
  color: #e64340;
  font-weight: 600;
}
.milestone-badge {
  font-size: 18rpx;
  color: #fff;
  background: #f59e0b;
  border-radius: 8rpx;
  padding: 2rpx 8rpx;
  margin-top: 4rpx;
  display: inline-block;
}
.calendar {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-wrap: wrap;
}
.calendar-row {
  width: 14.28%;
  text-align: center;
}
.calendar-day {
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #333;
  border-radius: 8rpx;
}
.calendar-day.signed {
  background: rgba(7,193,96,0.1);
  color: #07c160;
  font-weight: 600;
}
.calendar-day.today {
  background: #3b82f6;
  color: #fff;
}
.records {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
}
.record-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 26rpx;
  color: #333;
}
