/** app.wxss - V2.9.1 M16c 全局样式补全 */

/* ============================================
   1. 基础变量与页面
   ============================================ */
page {
  --primary: #3b82f6;
  --primary-dark: #2563eb;
  --secondary: #64748b;
  --accent: #f59e0b;
  --danger: #ef4444;
  --success: #22c55e;
  --warning: #eab308;
  --bg: #f8fafc;
  --bg-white: #ffffff;
  --bg-gray: #f1f5f9;
  --text: #1e293b;
  --text-secondary: #64748b;
  --text-muted: #94a3b8;
  --border: #e2e8f0;
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0,0,0,0.08);
  --shadow-lg: 0 8rpx 32rpx rgba(0,0,0,0.12);

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
  background-color: var(--bg);
  color: var(--text);
  font-size: 28rpx;
  line-height: 1.6;
}

/* ============================================
   2. 布局系统
   ============================================ */
.container {
  padding: 20rpx;
}

.container-sm {
  padding: 12rpx;
}

.container-lg {
  padding: 32rpx;
}

.flex {
  display: flex;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-wrap {
  flex-wrap: wrap;
}

.items-center {
  align-items: center;
}

.items-start {
  align-items: flex-start;
}

.justify-between {
  justify-content: space-between;
}

.justify-center {
  justify-content: center;
}

.flex-1 {
  flex: 1;
}

.gap-2 {
  gap: 16rpx;
}

.gap-3 {
  gap: 24rpx;
}

/* ============================================
   3. 间距
   ============================================ */
.m-0 { margin: 0; }
.m-1 { margin: 8rpx; }
.m-2 { margin: 16rpx; }
.m-3 { margin: 24rpx; }
.mt-1 { margin-top: 8rpx; }
.mt-2 { margin-top: 16rpx; }
.mt-3 { margin-top: 24rpx; }
.mb-1 { margin-bottom: 8rpx; }
.mb-2 { margin-bottom: 16rpx; }
.mb-3 { margin-bottom: 24rpx; }
.ml-1 { margin-left: 8rpx; }
.ml-2 { margin-left: 16rpx; }
.mr-1 { margin-right: 8rpx; }
.mr-2 { margin-right: 16rpx; }

.p-1 { padding: 8rpx; }
.p-2 { padding: 16rpx; }
.p-3 { padding: 24rpx; }
.py-2 { padding-top: 16rpx; padding-bottom: 16rpx; }
.px-2 { padding-left: 16rpx; padding-right: 16rpx; }

/* ============================================
   4. 卡片
   ============================================ */
.card {
  background: var(--bg-white);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
}

.card-flat {
  background: var(--bg-white);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid var(--border);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
}

.card-subtitle {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* ============================================
   5. 按钮
   ============================================ */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1;
  border: none;
  transition: opacity 0.2s;
}

.btn:active {
  opacity: 0.85;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: var(--primary);
  color: #fff;
}

.btn-secondary {
  background: var(--secondary);
  color: #fff;
}

.btn-success {
  background: var(--success);
  color: #fff;
}

.btn-danger {
  background: var(--danger);
  color: #fff;
}

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
}

.btn-ghost {
  background: transparent;
  color: var(--text-secondary);
}

.btn-sm {
  padding: 10rpx 20rpx;
  font-size: 24rpx;
}

.btn-lg {
  padding: 20rpx 40rpx;
  font-size: 32rpx;
}

.btn-block {
  width: 100%;
}

.btn-round {
  border-radius: 9999rpx;
}

/* ============================================
   6. 表单
   ============================================ */
.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text);
  margin-bottom: 8rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: var(--bg-white);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  color: var(--text);
  box-sizing: border-box;
}

.form-input:focus {
  border-color: var(--primary);
}

.form-textarea {
  width: 100%;
  padding: 16rpx 20rpx;
  background: var(--bg-white);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  color: var(--text);
  min-height: 200rpx;
  box-sizing: border-box;
}

.form-select {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: var(--bg-white);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  color: var(--text);
}

.form-hint {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

/* ============================================
   7. 列表
   ============================================ */
.list {
  background: var(--bg-white);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--border);
}

.list-item:last-child {
  border-bottom: none;
}

.list-item:active {
  background: var(--bg-gray);
}

.list-media {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-sm);
  margin-right: 20rpx;
  background: var(--bg-gray);
  flex-shrink: 0;
}

.list-body {
  flex: 1;
  min-width: 0;
}

.list-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.list-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.list-meta {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

.list-action {
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* ============================================
   8. 图文混排
   ============================================ */
.title {
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.4;
  margin-bottom: 12rpx;
  color: var(--text);
}

.desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.meta {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 12rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1;
}

.tag-primary {
  background: rgba(59, 130, 246, 0.1);
  color: var(--primary);
}

.tag-success {
  background: rgba(34, 197, 94, 0.1);
  color: var(--success);
}

.tag-warning {
  background: rgba(234, 179, 8, 0.1);
  color: var(--warning);
}

.tag-danger {
  background: rgba(239, 68, 68, 0.1);
  color: var(--danger);
}

/* ============================================
   9. 状态与反馈
   ============================================ */
.empty {
  text-align: center;
  padding: 100rpx 40rpx;
  color: var(--text-muted);
  font-size: 28rpx;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  color: var(--text-muted);
  font-size: 26rpx;
}

.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.75);
  color: #fff;
  padding: 20rpx 40rpx;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  z-index: 9999;
}

/* ============================================
   10. 工具类
   ============================================ */
.text-center { text-align: center; }
.text-left { text-align: left; }
.text-right { text-align: right; }

.text-primary { color: var(--primary); }
.text-secondary { color: var(--text-secondary); }
.text-muted { color: var(--text-muted); }
.text-danger { color: var(--danger); }
.text-success { color: var(--success); }

.font-bold { font-weight: 600; }
.font-normal { font-weight: 400; }

.text-sm { font-size: 24rpx; }
.text-base { font-size: 28rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }

.bg-white { background: var(--bg-white); }
.bg-gray { background: var(--bg-gray); }

.rounded { border-radius: var(--radius-md); }
.rounded-lg { border-radius: var(--radius-lg); }

.shadow { box-shadow: var(--shadow-sm); }
.shadow-md { box-shadow: var(--shadow-md); }

.overflow-hidden { overflow: hidden; }
.truncate {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.divider {
  height: 1rpx;
  background: var(--border);
  margin: 20rpx 0;
}

.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
