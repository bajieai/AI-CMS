/** app.wxss - 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
  background-color: #f5f5f5;
  color: #333;
}

.container {
  padding: 20rpx;
}

.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

.btn-primary {
  background: #07c160;
  color: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.btn-primary::after {
  border: none;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}
