# 应用配置
APP_DEBUG = false
APP_TRACE = false

# 服务器配置
HOST = 0.0.0.0
PORT = 8080

# 数据库配置
DB_HOST = 127.0.0.1
DB_PORT = 3306
DB_USER = root
DB_PASS = root
DB_NAME = aicms
DB_CHARSET = utf8mb4
DB_PREFIX = i8j_aicms_

# Redis配置
REDIS_HOST = 127.0.0.1
REDIS_PORT = 6379
REDIS_PASS =
REDIS_DB = 0

# JWT配置
JWT_SECRET = your-jwt-secret-key-change-in-production
JWT_EXPIRE = 7200
JWT_REFRESH_EXPIRE = 604800

# AI服务配置
AI_DEEPSEEK_API_KEY = your-deepseek-api-key
AI_DEEPSEEK_BASE_URL = https://api.deepseek.com
AI_DEFAULT_MODEL = deepseek-chat
AI_MAX_TOKENS = 4096
AI_TEMPERATURE = 0.7

# 上传配置
UPLOAD_PATH = ./uploads
UPLOAD_MAX_SIZE = 10485760
UPLOAD_ALLOWED_TYPES = jpg,jpeg,png,gif,webp,mp4,mp3,zip,pdf,doc,docx,xls,xlsx

# 图片处理
IMAGE_THUMB_WIDTH = 300
IMAGE_THUMB_HEIGHT = 300
IMAGE_QUALITY = 85

# CORS配置
CORS_ALLOW_ORIGIN = *
CORS_ALLOW_METHODS = GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS = Content-Type,Authorization,X-Requested-With,Accept,Origin
CORS_EXPOSE_HEADERS = Content-Length,Content-Type,Access-Control-Allow-Origin
CORS_MAX_AGE = 86400

# 日志配置
LOG_LEVEL = error,warning,info
LOG_CHANNEL = file

# 缓存配置
CACHE_DRIVER = redis
CACHE_PREFIX = aicms_

# 会话配置
SESSION_TYPE = redis
SESSION_EXPIRE = 7200

# 操作日志
LOG_OPERATION_ENABLED = true
LOG_OPERATION_EXCLUDE = /api/auth/login,/api/ai/stats
