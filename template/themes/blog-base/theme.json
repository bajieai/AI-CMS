{
  "name": "个人博客基底",
  "version": "1.0.0",
  "description": "个人博客风格主题基底，简洁排版 + 文章列表 + 标签云 + 归档时间线",
  "author": "八界AI-CMS",
  "category": "blog",
  "tags": ["博客", "个人", "写作", "阅读"],
  "preview": "",
  "type": "blog",
  "supports": ["pc", "mobile"],
  "default_device": "pc",
  "colors": {
    "primary": "#0f766e",
    "secondary": "#5a8f7b",
    "accent": "#14b8a6",
    "hero_gradient": "linear-gradient(135deg, #0f766e 0%, #134e4a 100%)"
  },
  "options": {
    "show_breadcrumb": false,
    "show_sidebar": true,
    "hero_enabled": false,
    "show_author_card": true,
    "show_tag_cloud": true,
    "show_archive": true,
    "show_recent_posts": true,
    "articles_per_page": 10,
    "excerpt_length": 200
  }
}