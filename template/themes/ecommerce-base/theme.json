{
  "name": "电商零售基底",
  "version": "1.0.0",
  "description": "电商零售风格主题基底，红色促销色系 + 商品卡片 + 购物车入口 + 限时活动区",
  "author": "八界AI-CMS",
  "category": "ecommerce",
  "tags": [
    "电商",
    "零售",
